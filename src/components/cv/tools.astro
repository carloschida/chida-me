---
import Badge from "@/components/ui/Badge.astro";
import Card from "@/components/ui/Card.astro";
import type { CvType } from "@/schemas/cv.ts";

interface Props {
  technologies: NonNullable<CvType["technologies"]>;
}

const { technologies } = Astro.props;
---

<Card
  class="flex flex-col gap-y-4 text-base md:text-sm lg:text-base md:p-4 lg:p-8 mb-4"
>
  <h2 class="font-bold text-primary text-lg">Tools</h2>
  <div class="flex flex-row flex-wrap justify-between gap-2">
    {
      technologies.map((tech) => (
        <Badge variant="outline">
          {typeof tech === "string" ? tech : tech.name}
        </Badge>
      ))
    }
  </div>
</Card>
